# Copy to .env for local dev. On Railway, set these as Variables instead —
# never commit a real .env.

# Generate both with: node -e "console.log(crypto.randomUUID())"
DM_TOKEN=
PLAYER_TOKEN=

# Where the SQLite file lives. MUST point at a persistent volume in
# production — Railway's container filesystem is wiped on every redeploy
# otherwise. Default is fine for local dev.
DB_PATH=./data/campaign.db

PORT=8080

# Comma-separated frontend origins allowed to call this API, e.g.
# "https://campaign.example.com". Leave unset for local dev against
# http://localhost:5175 — see index.js's CORS handling for exact behavior.
ALLOWED_ORIGINS=http://localhost:5175
