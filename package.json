{
  "name": "campaign-timeline-vtt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5175",
    "dev:open": "vite --host 0.0.0.0 --port 5175 --open",
    "dev:host": "vite --host 0.0.0.0 --open",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:hooks": "eslint . --format json | node scripts/check-hooks-lint.mjs",
    "lint:runtime": "npm run lint:hooks && npm run typecheck && npm run build",
    "audit:data": "node scripts/audit-campaign-data.mjs",
    "snapshot:promote": "node scripts/promote-overlay-snapshot.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 5175 --open",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
